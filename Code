income = float(input("Enter your total income: "))
expenses = float(input("Enter your total expenses: "))

savings_goal = float(input("Enter your savings goal: "))

remaining = income - expenses

print("\n--- Money Summary ---")
print("Income: $", income)
print("Expenses: $", expenses)
print("Remaining Money: $", remaining)
print("Savings Goal: $", savings_goal)

if remaining >= savings_goal:
    print("Great! You can reach your savings goal.")
else:
    print("You need to save more to reach your goal.")

if expenses > income:
    print("Warning: You spent more than you earned!")
elif expenses > income * 0.8:
    print("Reminder: You are close to your spending limit. Try to save more!")
else:
    print("Good job! Your spending is within your budget.")
