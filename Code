print(" MoneyMinder ")

income = float(input("Enter income: "))
savings_goal = float(input("Enter savings goal: "))

food = float(input("Food expense: "))
school = float(input("School expense: "))
transport = float(input("Transport expense: "))

total_expenses = food + school + transport
remaining = income - total_expenses
percent = (remaining / savings_goal) * 100

print("\n--- Summary ---")
print("Total Income:", income)
print("Total Expenses:", total_expenses)
print("Remaining Balance:", remaining)

print("\nExpenses by Category")
print("Food:", food)
print("School:", school)
print("Transport:", transport)

print("\nSavings Progress:", round(percent,2), "%")

if remaining >= savings_goal:
    print("You reached your savings goal!")
else:
    print("Reminder: Spend less to reach your goal.")
